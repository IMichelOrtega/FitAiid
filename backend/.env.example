# =============================================
# CONFIGURACIÓN DEL AMBIENTE
# Renombra este archivo a .env y llena con tus valores reales
# =============================================

# =============================================
# SERVIDOR
# =============================================
PORT=5000
NODE_ENV=development

# =============================================
# BASE DE DATOS - MONGODB
# =============================================
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/fitaiid?retryWrites=true&w=majority

# =============================================
# AUTENTICACIÓN - JWT
# =============================================
JWT_SECRET=tu-super-secreto-jwt-seguro-minimo-32-caracteres
JWT_EXPIRE=7d

# =============================================
# FRONTEND URLs
# =============================================
FRONTEND_URL=http://localhost:3000
FRONTEND_PROD_URL=https://tudominio.com

# =============================================
# FIREBASE ADMIN SDK
# Actualiza con tus credenciales reales
# =============================================
FIREBASE_PROJECT_ID=tu-proyecto-id
FIREBASE_PRIVATE_KEY=tu-private-key
FIREBASE_CLIENT_EMAIL=tu-email@firebase.gserviceaccount.com
FIREBASE_DATABASE_URL=https://tu-proyecto.firebaseio.com

# =============================================
# OPENAI API (Para generación de rutinas)
# =============================================
OPENAI_API_KEY=sk-tu-clave-api-aqui

# =============================================
# GOOGLE OAUTH (Sign-in con Google)
# =============================================
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-secret

# =============================================
# STRIPE (Pagos)
# =============================================
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================
# EMAIL (Nodemailer)
# =============================================
EMAIL_SERVICE=gmail
EMAIL_USER=tu-email@gmail.com
EMAIL_PASSWORD=tu-contraseña-app-específica
EMAIL_FROM=noreply@fitaiid.com

# =============================================
# WEB PUSH NOTIFICATIONS (VAPID Keys)
# =============================================
VAPID_PUBLIC_KEY=tu-clave-publica-vapid
VAPID_PRIVATE_KEY=tu-clave-privada-vapid

# =============================================
# SENTRY (Error tracking - Opcional)
# =============================================
SENTRY_DSN=https://...@sentry.io/...

# =============================================
# LOGGING
# =============================================
LOG_LEVEL=debug
LOG_DIR=./logs

# =============================================
# RATE LIMITING
# =============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================
# CORS ORIGINS (separadas por coma)
# =============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://tudominio.com
